# PostHog request analytics
#
# Prefer the current PostHog public names if the docs app also uses browser-side PostHog.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_your_project_token
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Server-side aliases accepted by src/proxy.ts.
# POSTHOG_PROJECT_API_KEY=phc_your_project_token
# POSTHOG_API_HOST=https://us.i.posthog.com

# Use https://eu.i.posthog.com for EU PostHog projects.
